.container { padding: 20rpx 30rpx 60rpx; background: #f5f0eb; min-height: 100vh; }
.header { text-align: center; padding: 40rpx 0 30rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #3d2b1f; display: block; }
.subtitle { font-size: 26rpx; color: #8b7355; margin-top: 10rpx; display: block; }

.config-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #3d2b1f; margin-bottom: 16rpx; }
.slider-label { font-size: 24rpx; color: #8b7355; text-align: center; display: block; margin-top: 8rpx; }

.chip-group { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip { padding: 12rpx 28rpx; border-radius: 32rpx; border: 2rpx solid #d4c5b2; font-size: 26rpx; color: #5c4a3a; background: #faf7f2; }
.chip-active { background: #3d2b1f; color: #fff; border-color: #3d2b1f; }

.inspo-input { width: 100%; min-height: 120rpx; font-size: 26rpx; color: #3d2b1f; padding: 16rpx; border: 1rpx solid #e0d5c7; border-radius: 12rpx; background: #faf7f2; }

.generate-btn { width: 100%; height: 96rpx; line-height: 96rpx; background: linear-gradient(135deg, #5c3d2e, #8b6914); color: #fff; border-radius: 48rpx; font-size: 32rpx; font-weight: bold; margin: 30rpx 0; border: none; }
.generate-btn.loading { opacity: 0.6; }
.generate-btn[disabled] { background: #c4b5a5; }

.error { background: #fff0f0; color: #c0392b; padding: 20rpx; border-radius: 12rpx; font-size: 26rpx; margin-bottom: 20rpx; }

.result { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.result-title { font-size: 32rpx; font-weight: bold; color: #3d2b1f; }
.result-badge { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 16rpx; background: #e8f5e9; color: #2e7d32; }
.result-badge.source-demo { background: #fff3e0; color: #e65100; }
.result-meta { font-size: 24rpx; color: #8b7355; margin-bottom: 20rpx; }

.result-preview { }
.preview-section { padding: 16rpx 0; border-bottom: 1rpx solid #f0ebe3; }
.preview-label { font-size: 26rpx; font-weight: bold; color: #5c4a3a; display: block; margin-bottom: 8rpx; }
.preview-char { font-size: 24rpx; color: #6b5b4a; display: block; padding: 4rpx 0; }

.detail-btn { width: 100%; height: 80rpx; line-height: 80rpx; background: #3d2b1f; color: #fff; border-radius: 40rpx; font-size: 28rpx; margin-top: 20rpx; border: none; }

.bottom-nav { text-align: center; padding: 30rpx 0; }
.nav-link { color: #8b6914; font-size: 26rpx; text-decoration: underline; }
